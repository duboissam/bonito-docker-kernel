DEVICE_ID="bonito"
DEVICE_LABEL="Pixel 3a XL"
ANDROID_DEVICES=(bonito)
KERNEL_REPO="https://github.com/LineageOS/android_kernel_google_msm-4.9.git"
DEFAULT_KERNEL_REF="lineage-22.2"
DEFCONFIG="bonito_defconfig"
KBUILD_HOST="bonito-docker"
MODULE_ORDER=(
  lcd.ko
  wlan.ko
)
MODULE_SPECS=(
  "lcd.ko:drivers/video/backlight/lcd.ko"
  "wlan.ko:drivers/staging/qcacld-3.0/wlan.ko"
)
